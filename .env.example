APP_ENV=development
POSTGRES_DB=markets_strategy_copilot
POSTGRES_USER=markets
POSTGRES_PASSWORD=markets
DATABASE_URL=postgresql+psycopg://markets:markets@localhost:5432/markets_strategy_copilot
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
LIVE_DEFAULT_MODE=demo
OPENAI_API_KEY=
# Optional server-side OpenAI model override for explanations/report drafting.
# "latest" maps inside this app to the latest supported model ID currently documented for the project.
OPENAI_MODEL=latest
POLYGON_API_KEY=
NEWSAPI_API_KEY=

# Optional market data, macro, and filing integrations.
# Keep these server-side only. Do not expose them to the browser.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
FRED_API_KEY=
SEC_USER_AGENT=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
FMP_API_KEY=

# Additional free-tier / no-paid-plan research enrichments.
# These are optional, server-side only, and should degrade cleanly if absent
# or rate-limited. Check each provider's current free-tier limits before use.
TWELVEDATA_API_KEY=
MARKETAUX_API_KEY=
EODHD_API_KEY=

# Optional auth / workspace integration.
# If absent, the app runs in local guest mode.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional outbound email alerts.
# If RESEND_FROM_EMAIL is absent, email delivery is disabled cleanly.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
